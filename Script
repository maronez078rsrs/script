local function NewSlider(yPos, parent, min, max, callback)
    local bg = Instance.new("Frame", parent)
    bg.Size = UDim2.new(0.8, 0, 0, 4); bg.Position = UDim2.new(0.1, 0, 0, yPos); bg.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    local knob = Instance.new("TextButton", bg)
    knob.Size = UDim2.new(0, 12, 0, 12); knob.Position = UDim2.new(0, 0, 0.5, -6); knob.Text = ""
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    local dragging = false
    knob.MouseButton1Down:Connect(function() dragging = true end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    RunService.RenderStepped:Connect(function()
        if dragging then
            local pos = math.clamp((Mouse.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
            knob.Position = UDim2.new(pos, -6, 0.5, -6)
            callback(min + (max - min) * pos)
        end
    end)
end

