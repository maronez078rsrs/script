-- ESP DRAWING (TOP LINES)
local function ESP(plr)
    local l1 = Drawing.new("Line"); l1.Visible = false; l1.Thickness = 1; l1.Color = Color3.new(1,1,1)
    local hb = Drawing.new("Line"); hb.Visible = false; hb.Thickness = 3; hb.Color = Color3.new(0,0,0)
    local gh = Drawing.new("Line"); gh.Visible = false; gh.Thickness = 1.5; gh.Color = Color3.new(0,1,0)

    RunService.RenderStepped:Connect(function()
        if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character.Humanoid.Health > 0 then
            local pos, screen = Camera:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position)
            if screen and not (_G.Config.TeamCheck and plr.Team == LocalPlayer.Team) then
                local head = Camera:WorldToViewportPoint(plr.Character.Head.Position)
                local dy = math.abs(head.Y - pos.Y)
                
                if _G.Config.EspLines then
                    l1.Visible = true; l1.From = Vector2.new(Camera.ViewportSize.X/2, 0); l1.To = Vector2.new(pos.X, pos.Y - dy*2); l1.Color = plr.TeamColor.Color
                else l1.Visible = false end
                
                if _G.Config.EspLife then
                    local side = Camera:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position + plr.Character.HumanoidRootPart.CFrame.RightVector * -1.8)
                    local hp = plr.Character.Humanoid.Health / plr.Character.Humanoid.MaxHealth
                    hb.Visible = true; hb.From = Vector2.new(side.X, pos.Y + dy*2); hb.To = Vector2.new(side.X, pos.Y - dy*2)
                    gh.Visible = true; gh.From = Vector2.new(side.X, pos.Y + dy*2); gh.To = Vector2.new(side.X, (pos.Y + dy*2) - (dy*4*hp)); gh.Color = Color3.new(1,0,0):lerp(Color3.new(0,1,0), hp)
                else hb.Visible = false; gh.Visible = false end
            else l1.Visible = false; hb.Visible = false; gh.Visible = false end
        else l1.Visible = false; hb.Visible = false; gh.Visible = false end
    end)
end

